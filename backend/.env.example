DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blog
SECRET_KEY=change-me-in-production

# 토스페이먼츠 결제 시크릿키 (서버 전용 — 절대 프론트/커밋 금지).
# 비워두면 코드 기본값(토스 공개 테스트 키)로 동작 → 실제 청구 없음.
# 라이브 전환: 토스 대시보드(사업자 등록·심사 후)에서 발급한 라이브 시크릿키(live_sk_...)를
# 여기(운영 서버 .env)에 넣으면 실제 결제가 승인된다. 프론트 클라이언트키(live_ck_...)와
# 반드시 같은 상점의 키 쌍이어야 승인됨(클라이언트키는 GitHub Variables의 TOSS_CLIENT_KEY로 주입).
# TOSS_SECRET_KEY=live_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# 운영 안전장치: 아래를 true로 두면 시크릿키가 test_로 시작할 때 결제 승인을 거부한다.
# → 운영에 실수로 테스트 키가 남아도 '공짜 Pro'가 뿌려지지 않음. 로컬/데모는 미설정(false).
# PAYMENTS_REQUIRE_LIVE=true
# 구독 유지 기간(일). 결제 시 이 일수만큼만 Pro 유지되고 지나면 자동 해제(기본 30).
# PRO_DAYS=30

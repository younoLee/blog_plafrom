# 운영 서버(EC2 `~/blog/.env`) 템플릿.
#
# ⚠️ 로컬 개발용이 아니다. 개발은 저장소 루트의 `.env.example`을 보라 —
#    개발에서 .env로 치환되는 건 ANTHROPIC_API_KEY·LLM_ENCRYPTION_KEY 둘뿐이고,
#    나머지는 docker-compose.yml의 environment 블록에 이미 들어 있다.
#
# 이 파일의 쓸모: 사본을 전부 잃었을 때 **무엇을 채워야 하는지**의 목록이다
# (RECOVERY.md 시나리오 D). 실제 값은 세 곳에 있다 —
#   EC2 `~/blog/.env` · 이 PC `~/.blog-secrets/prod.env` · SSM `/blog/prod/env`
#   대조: scripts/env_escrow.sh check
#
# ⚠️ 잃었을 때 유일하게 **복구 불가**한 건 LLM_ENCRYPTION_KEY다. 나머지는 재발급된다.

# ── 앱 핵심 ────────────────────────────────────────────────────────────────
# 컨테이너 안에서 db 서비스를 가리킨다. 비밀번호는 아래 DB_PASSWORD와 같아야 한다.
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db:5432/postgres
# JWT 서명 키. 16자 미만이거나 기본값이면 앱이 아예 안 뜬다(main.py의 fail-closed 가드).
# 바뀌면 발급된 모든 세션이 무효 → 사용자는 다시 로그인하면 된다(복구 가능).
#   생성: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
# db 컨테이너의 postgres 비밀번호. compose가 이 값을 db 서비스에 넣는다(앱은 안 읽는다).
DB_PASSWORD=

# ── BYOK 암호화 (잃으면 끝) ────────────────────────────────────────────────
# 사용자가 맡긴 외부 LLM 키를 Fernet으로 암호화해 llm_credentials에 저장한다.
# 이 값을 잃으면 DB 백업이 완벽해도 그 암호문을 **영원히** 못 푼다. 재발급이 아니라
# 데이터 손실이다. 교체하려면 기존 암호문을 옛 키로 풀어 새 키로 다시 암호화해야 한다.
#   생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_ENCRYPTION_KEY=

# ── 메일 (SES) ─────────────────────────────────────────────────────────────
# 자격증명은 SES 콘솔에서 재발급 가능. 단, 계정이 샌드박스면 검증된 주소로만 나간다
# — 그건 여기 설정이 아니라 계정 상태다(docs/ses-production-access.md).
SMTP_HOST=email-smtp.ap-northeast-2.amazonaws.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=

# ── 외부 API ───────────────────────────────────────────────────────────────
# 서버 키로 도는 AI 초안. 비우면 /api/ai/draft가 503으로 안내하고 나머지는 정상.
# ⚠️ 로컬 개발과 같은 키를 쓰지 말 것(사용량 분리·개별 폐기 불가).
ANTHROPIC_API_KEY=

# ── 인프라 참조값 (시크릿 아님, 저장소·terraform에서 재구성 가능) ──────────
PUBLIC_BASE_URL=https://d2j66m9udyg9yq.cloudfront.net
FRONTEND_BASE_URL=https://d2j66m9udyg9yq.cloudfront.net
S3_BUCKET=blogplafromops
AWS_REGION=ap-northeast-2
ADMIN_EMAIL=

# ── 결제 안전장치 ──────────────────────────────────────────────────────────
# true면 시크릿키가 test_로 시작할 때 결제 승인을 503으로 거부한다.
# 운영에 테스트 키가 남아 '공짜 Pro'가 뿌려지는 걸 원천 차단하는 밸브.
# 2026-07-22 이전엔 이 항목이 아예 없어서 코드 기본값(false)으로 돌고 있었다.
PAYMENTS_REQUIRE_LIVE=true
# 라이브 전환 시 토스 대시보드의 라이브 시크릿키(live_sk_...)를 넣는다.
# 프론트 클라이언트키(live_ck_..., GitHub Variables의 TOSS_CLIENT_KEY)와 같은 상점이어야 한다.
# TOSS_SECRET_KEY=

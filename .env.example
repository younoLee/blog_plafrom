# 로컬 개발용 — 이 파일을 `.env`로 복사해서 쓴다. (`.env`는 gitignore됨)
#
# ⚠️ 운영 `.env`를 여기 복사하지 말 것. 이건 완전히 다른 파일이다.
#    운영 값(SECRET_KEY·DB_PASSWORD·SES 자격증명 등)은 EC2 `~/blog/.env`에만 있고,
#    사본은 `~/.blog-secrets/prod.env`와 SSM `/blog/prod/env`에 있다.
#    운영 템플릿이 궁금하면 `backend/.env.example`을 볼 것.
#
# 여기 넣을 건 **딱 두 개**다. 나머지(DATABASE_URL·SECRET_KEY·SMTP 등)는
# `docker-compose.yml`의 environment 블록에 개발용 값으로 이미 박혀 있어서
# 이 파일에 안 써도 된다 — 치환되는 변수는 이 둘뿐이다.
#
# 둘 다 비워도 스택은 정상적으로 뜬다. 해당 기능만 꺼진다.

# AI 초안 생성(Claude). 비우면 /api/ai/draft가 503으로 안내하고 나머지는 정상.
# ⚠️ 운영과 같은 키를 쓰지 말 것 — 따로 발급하면 사용량을 분리해 보고,
#    한쪽이 유출돼도 다른 쪽을 살린 채 폐기할 수 있다.
ANTHROPIC_API_KEY=

# BYOK(사용자가 맡긴 GPT/Gemini 키) 암호화용 Fernet 키. 비우면 BYOK 저장이 비활성.
# ⚠️ 반드시 운영과 다른 값으로. 로컬용은 아래로 새로 만들면 된다(무료):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_ENCRYPTION_KEY=
